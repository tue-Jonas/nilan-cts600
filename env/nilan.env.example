# Copy to env/nilan.env and fill in. (env/nilan.env is gitignored — holds secrets.)

# --- Device mode -------------------------------------------------------------
# 1 = mockup (no hardware, frodef CTS600Mockup) — use until the ESP bridge is live.
# 0 = real device via socat tunnel (requires ESP_IP below).
NILAN_MOCKUP=1

# ESP32 bridge endpoint (set once Wattson reports the live/static IP from TUE-16).
ESP_IP=
ESP_PORT=6638

NILAN_PORT=/dev/ttyNILAN
NILAN_RETRIES=3
NILAN_POLL_SECONDS=30
NILAN_T15_FALLBACK=21

# Provisional sensor->contract mapping; confirm against the unit nameplate (TUE-16 §11).
NILAN_T_ROOM_KEY=T15
NILAN_T_SUPPLY_KEY=T1
NILAN_T_EXHAUST_KEY=T5

# --- HTTP --------------------------------------------------------------------
NILAN_HTTP_HOST=0.0.0.0
NILAN_HTTP_PORT=8642
# Optional bearer token for direct API access (auth is primarily at the Caddy proxy).
NILAN_API_TOKEN=

# --- MQTT --------------------------------------------------------------------
# MQTT_HOST is injected as "mosquitto" by docker-compose. For host runs set it here.
MQTT_PORT=1883
MQTT_USER=nilan
MQTT_PASS=CHANGE_ME
MQTT_BASE_TOPIC=nilan
