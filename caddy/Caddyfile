# Reverse proxy + basic auth for the Nilan REST API (local-first).
# Exposed on :8643; proxies to the internal nilan-api:8642.
# Replace the bcrypt hash below with your own:
#   docker run --rm caddy:2 caddy hash-password --plaintext '<your-password>'
# Default user: nilan
:8643 {
	basic_auth {
		nilan REPLACE_ME__run: caddy hash-password --plaintext <pw>
	}
	reverse_proxy nilan-api:8642
	encode gzip
	log {
		output stdout
		level INFO
	}
}
